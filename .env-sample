# ======================================
# LLM Provider Configuration
# ======================================
# Set to 'false' for OpenAI (default), or 'true' for Azure OpenAI (DIAL)
USE_AZURE_OPENAI=false

# ======================================
# OpenAI Configuration
# (Used when USE_AZURE_OPENAI=false)
# ======================================
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4o-mini

# ======================================
# Azure OpenAI (DIAL) Configuration
# (Used when USE_AZURE_OPENAI=true)
# ======================================
AZURE_API_KEY=your-azure-api-key-here
AZURE_ENDPOINT=https://ai-proxy.lab.epam.com
AZURE_API_VERSION=2024-02-01
AZURE_DEPLOYMENT_NAME=gpt-4
AZURE_EMBEDDING_MODEL=text-embedding-3-small-1

# ======================================
# RAG Configuration
# ======================================
LLM_TEMPERATURE=0
CHUNK_SIZE=500
CHUNK_OVERLAP=50

